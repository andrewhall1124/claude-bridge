# Bridge configuration via environment variables.
# Everything here can also be set in config.json (env vars take precedence).
# Copy to .env (loaded automatically) or export these in the service environment.

# Port the server listens on.
PORT=8787

# Bind ONLY to the Tailscale interface. Use the VPS's tailnet IP (100.x.y.z)
# or its MagicDNS hostname. Never 0.0.0.0 on a public interface.
BIND_ADDRESS=127.0.0.1

# Path to the SQLite database file (created on first run).
DB_PATH=./data/bridge.sqlite

# Default model alias passed to the Agent SDK: opus | sonnet | haiku
# (aliases track the latest model so they don't go stale).
DEFAULT_MODEL=opus

# Default permission mode for chat sessions:
#   default | acceptEdits | plan | bypassPermissions
# bypassPermissions runs every tool unprompted — only on a trusted, tailnet-only box.
DEFAULT_PERMISSION_MODE=default

# Comma-separated repo definitions as id:name:path, OR leave unset and use
# config.json's "repos" array. Example:
# REPOS=web:My Web App:/srv/repos/web,api:API Service:/srv/repos/api

# Optional: directory scanned for repos (each subdir becomes a repo).
# REPOS_DIR=/srv/repos

# Optional — Railway Deploy page. Set an account-scoped token to enable the
# Deploy tab, which shows the latest deployment + status per service. Each repo
# is linked to a Railway project in the UI (Deploy page), so no project id here.
# Get a token at https://railway.com/account/tokens
# RAILWAY_API_TOKEN=your-token
# RAILWAY_ENVIRONMENT=production           # default environment to show

# IMPORTANT — billing:
# Leave ANTHROPIC_API_KEY UNSET to bill usage against your Claude subscription
# (the bundled Claude Code CLI uses the credentials stored by `claude login`).
# Setting it switches to pay-as-you-go API-key billing — the escape hatch.
# ANTHROPIC_API_KEY=sk-ant-...
